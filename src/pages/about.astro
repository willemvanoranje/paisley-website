---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Paisley — About">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-20">
    <!-- Bio Section -->
    <section class="mb-16">
      <div>
        <h1 class="font-display text-3xl sm:text-4xl font-light tracking-wide text-gray-900 mb-6">
          About
        </h1>
        <p class="text-gray-600 leading-relaxed mb-4">
          I'm a photographer and visual storyteller with a Bachelor's in Art from
          Western Michigan University's Gwen Frostic School of Art and a minor in
          Marketing from the Haworth College of Business. My background blends
          creative media production with marketing strategy.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          From capturing athletic highlights for WMU Track &amp; Field to producing
          marketing visuals for events nationwide, I bring an eye for authentic
          moments and a knack for engaging audiences across print, video, and social
          media.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Based in Chicago, IL.
        </p>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="mb-16">
      <h2 class="font-display text-xl tracking-widest uppercase text-gray-900 mb-8 pb-3 border-b border-gray-200">
        Experience
      </h2>
      <div class="space-y-8">
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            Jan 2024 — Present
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Assistant Property Manager / Licensed Leasing Agent — Chicago, IL</h3>
            <p class="text-gray-500 text-sm mt-1">
              Supporting daily operations of a luxury high-rise with 600+ units.
              Managing applications, leasing, renewals, and tenant communications.
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            Aug — Dec 2023
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Marketing Intern — All Community Events, Lake Zurich, IL</h3>
            <p class="text-gray-500 text-sm mt-1">
              Produced marketing visuals—video, photography, and graphics—for events
              nationwide. Managed 30+ social media accounts and created press releases
              and email marketing campaigns.
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            Dec 2022 — May 2023
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Media Production — Photography &amp; Social Media (Volunteer)</h3>
            <p class="text-gray-500 text-sm mt-1">
              Western Michigan University Track &amp; Field. Captured and edited video/photo
              content for team promotion and fan engagement.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="mb-16">
      <h2 class="font-display text-xl tracking-widest uppercase text-gray-900 mb-8 pb-3 border-b border-gray-200">
        Skills
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        {[
          "Photography & Print Media",
          "Adobe Creative Suite",
          "Social Media Marketing",
          "Press Releases",
          "Email Marketing",
          "Customer Service & Sales",
          "Leasing & Renewals",
          "Market Research & Data Entry",
          "Microsoft Excel / Yardi / RentCafe",
        ].map((skill) => (
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300" />
            <span class="text-sm text-gray-600">{skill}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Education Section -->
    <section>
      <h2 class="font-display text-xl tracking-widest uppercase text-gray-900 mb-8 pb-3 border-b border-gray-200">
        Education
      </h2>
      <div class="space-y-8">
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            Western Michigan University
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Bachelor's Degree of Art — Gwen Frostic School of Art</h3>
            <p class="text-gray-500 text-sm mt-1">
              Minor: Marketing, Haworth College of Business
            </p>
            <p class="text-gray-500 text-sm mt-1">
              NCAA Division I Cross Country, Indoor &amp; Outdoor Track · Academic All-MAC · Dean's List · 4-Year Athletic Scholarship
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
