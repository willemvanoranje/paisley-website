---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Paisley — About">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-20">
    <!-- Bio Section -->
    <section class="mb-16">
      <div class="flex flex-col md:flex-row gap-10 items-start">
        <div class="w-full md:w-1/3 shrink-0">
          <img
            src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400&q=80"
            alt="Paisley — Photographer"
            class="w-full aspect-[3/4] object-cover rounded-sm"
          />
        </div>
        <div class="flex-1">
          <h1 class="font-display text-3xl sm:text-4xl font-light tracking-wide text-gray-900 mb-6">
            About
          </h1>
          <p class="text-gray-600 leading-relaxed mb-4">
            I'm a photographer passionate about capturing authentic moments and telling
            visual stories. With over a decade of experience spanning portrait, landscape,
            wedding, and commercial photography, I bring a natural and emotive approach to
            every project.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            My work is driven by a love for natural light and genuine human connection.
            Whether it's a quiet portrait session, an adventurous elopement, or a product
            shoot, I aim to create images that feel timeless and true.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Based in Chicago, IL, USA.
          </p>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="mb-16">
      <h2 class="font-display text-xl tracking-widest uppercase text-gray-900 mb-8 pb-3 border-b border-gray-200">
        Experience
      </h2>
      <div class="space-y-8">
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            2019 — Present
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Freelance Photographer</h3>
            <p class="text-gray-500 text-sm mt-1">
              Portrait, wedding, commercial, and editorial photography for clients
              across North America and Europe.
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            2016 — 2019
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Studio Photographer — Lumière Studio</h3>
            <p class="text-gray-500 text-sm mt-1">
              Lead photographer for portrait and product sessions. Managed studio
              lighting setups and post-production workflows.
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            2014 — 2016
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Photo Assistant — Harper & Co.</h3>
            <p class="text-gray-500 text-sm mt-1">
              Assisted senior photographers on editorial and advertising shoots.
              Equipment management and on-location support.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="mb-16">
      <h2 class="font-display text-xl tracking-widest uppercase text-gray-900 mb-8 pb-3 border-b border-gray-200">
        Skills
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        {[
          "Portrait Photography",
          "Landscape & Nature",
          "Wedding & Events",
          "Product Photography",
          "Photo Editing",
          "Studio Lighting",
          "Adobe Lightroom",
          "Adobe Photoshop",
          "Capture One",
        ].map((skill) => (
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300" />
            <span class="text-sm text-gray-600">{skill}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Education Section -->
    <section>
      <h2 class="font-display text-xl tracking-widest uppercase text-gray-900 mb-8 pb-3 border-b border-gray-200">
        Education
      </h2>
      <div class="space-y-8">
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            2010 — 2014
          </span>
          <div>
            <h3 class="font-medium text-gray-800">BFA in Photography</h3>
            <p class="text-gray-500 text-sm mt-1">
              School of Visual Arts, New York
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
          <span class="text-sm text-gray-400 font-display tracking-wide sm:w-36 shrink-0">
            2018
          </span>
          <div>
            <h3 class="font-medium text-gray-800">Advanced Lighting Workshop</h3>
            <p class="text-gray-500 text-sm mt-1">
              International Center of Photography, New York
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
