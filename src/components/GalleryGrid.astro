---
interface GalleryImage {
  src: string;
  alt: string;
  aspect: "portrait" | "landscape" | "square";
}

const images: GalleryImage[] = [
  {
    src: "/portfolio/india-travel.jpg",
    alt: "India travel photography — polaroid grid of street scenes from Kolkata and West Bengal",
    aspect: "portrait",
  },
  {
    src: "/portfolio/flam-norway.jpg",
    alt: "Flåm, Norway — travel poster featuring a sheep at Brekkenfossen",
    aspect: "portrait",
  },
  {
    src: "/portfolio/focus-strength.jpg",
    alt: "Focus Becomes Strength — fitness training poster design",
    aspect: "portrait",
  },
  {
    src: "/portfolio/banff-alberta.jpg",
    alt: "Banff, Alberta — travel poster with blue-toned landscape",
    aspect: "portrait",
  },
];
---

<div class="masonry-grid">
  {images.map((image, index) => (
    <div class="masonry-item">
      <button
        class="gallery-item block w-full overflow-hidden rounded-sm cursor-pointer group focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400"
        data-index={index}
        data-src={image.src}
        data-alt={image.alt}
      >
        <img
          src={image.src}
          alt={image.alt}
          loading={index < 4 ? "eager" : "lazy"}
          decoding="async"
          class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </button>
    </div>
  ))}
</div>
