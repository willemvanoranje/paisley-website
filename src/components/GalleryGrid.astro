---
import fs from "node:fs";
import path from "node:path";

const PORTFOLIO_DIR = path.join(process.cwd(), "public", "portfolio");
const IMAGE_EXTS = new Set([".jpg", ".jpeg", ".png", ".webp", ".avif", ".gif"]);

const files = fs.existsSync(PORTFOLIO_DIR)
  ? fs.readdirSync(PORTFOLIO_DIR)
      .filter((f) => IMAGE_EXTS.has(path.extname(f).toLowerCase()))
      .sort((a, b) => a.localeCompare(b))
  : [];

const images = files.map((file) => {
  const name = path.basename(file, path.extname(file));
  const alt = name.replace(/[-_]/g, " ");
  return { src: `/portfolio/${file}`, alt };
});
---

<div class="masonry-grid">
  {images.map((image, index) => (
    <div class="masonry-item">
      <button
        class="gallery-item block w-full overflow-hidden rounded-sm cursor-pointer group focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400"
        data-index={index}
        data-src={image.src}
        data-alt={image.alt}
      >
        <img
          src={image.src}
          alt={image.alt}
          loading={index < 4 ? "eager" : "lazy"}
          decoding="async"
          class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </button>
    </div>
  ))}
</div>
